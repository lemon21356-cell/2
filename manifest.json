{
  "manifest_version": 3,
  "name": "엔트리 블록 청소기",
  "version": "1.1",
  "permissions": ["scripting"],
  "host_permissions": ["https://playentry.org/*"],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://playentry.org/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://playentry.org/ws*"],
      "js": ["content.js"]
    }
  ]
}
